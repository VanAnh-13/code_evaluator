# === Code Analyzer API Configuration ===

# Provider: openai | anthropic | gemini | ollama
API_PROVIDER=openai

# Your API key (required for openai, anthropic, gemini; not needed for ollama)
API_KEY=sk-your-api-key-here

# Model name (optional, uses provider default if empty)
# OpenAI:    gpt-4o-mini, gpt-4o, gpt-4-turbo
# Anthropic: claude-sonnet-4-20250514, claude-3-haiku-20240307
# Gemini:    gemini-2.0-flash, gemini-1.5-pro
# Ollama:    codellama, llama2, mistral, deepseek-coder (requires local Ollama server)
API_MODEL=

# Optional settings
API_TEMPERATURE=0.1
API_MAX_TOKENS=4096
API_TIMEOUT=120

# Custom API base URL (for proxies or compatible APIs)
# API_BASE_URL=
# For Ollama (local): API_BASE_URL=http://localhost:11434

# Flask secret key (auto-generated if not set)
# SECRET_KEY=your-secret-key-here
